{
  "name": "tomin.world",
  "private": true,
  "version": "1.0.0",
  "description": "Shouli's portfolio site",
  "scripts": {
    "sync": "node sync.js",
    "watch": "node sync.js --watch",
    "compress": "./compress.sh",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --watch",
    "build": "npm run build:css && npm run sync",
    "publish": "npm run compress && npm run build"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "tailwindcss": "^3.4.17"
  }
}
