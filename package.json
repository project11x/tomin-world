{
  "name": "tomin.world",
  "private": true,
  "version": "1.0.0",
  "description": "Shouli's portfolio site",
  "type": "module",
  "scripts": {
    "sync": "node sync.cjs",
    "watch": "node sync.cjs --watch",
    "compress": "./compress.sh",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --watch",
    "build": "npm run build:css && npm run sync && vite build",
    "dev": "vite",
    "publish": "npm run compress && npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --project jsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.2.4",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
