{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": false,
    "noEmit": true,
    "allowJs": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": ["app.js", "admin.js", "push.js", "changelog.js", "data.js"],
  "exclude": ["node_modules", "dist", "test-results", "playwright-report", "tests"]
}
